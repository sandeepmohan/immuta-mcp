# Copy to .env and fill in. Tested against self-managed Immuta 2026.1.4.

# Immuta API key with permission to read datasources, policies, domains,
# users (BIM), and Insights→Audit. Generate under Profile → API Keys.
IMMUTA_API_KEY=your-api-key-here

# Base URL of the Immuta instance (NOT this MCP server). From inside the
# same k8s cluster prefer the service URL, e.g.
# http://immuta-secure.<namespace>.svc.cluster.local:8823
IMMUTA_BASE_URL=https://immuta.example.com

# Only required for the HTTP transport (--transport http). The server
# rejects every request without a matching "Authorization: Bearer <token>"
# header, and refuses to start if this is unset. Generate: openssl rand -hex 32
#MCP_BEARER_TOKEN=
